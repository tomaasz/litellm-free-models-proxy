# Copy this file to .env and fill in your API keys

# ── LiteLLM ────────────────────────────────────────────────────────────────────
# Set to true to automatically remove models that disappear from provider APIs
# CLEANUP_STALE_MODELS=true
LITELLM_MASTER_KEY=sk-litellm-your-master-key
LITELLM_SALT_KEY=sk-salt-your-salt-key
UI_USERNAME=admin
UI_PASSWORD=changeme
DATABASE_URL=postgresql://litellm:password@postgres:5432/litellm
STORE_MODEL_IN_DB=True

# ── Providers — add keys for the providers you want to use ────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
GROQ_API_KEY=gsk_...
GROQ_API_KEY_2=gsk_...          # optional second key for load-balancing
CEREBRAS_API_KEY=csk-...
SAMBANOVA_API_KEY=...
NVIDIA_NIM_API_KEY=nvapi-...
COHERE_API_KEY=...
TOGETHER_API_KEY=tgp_v1_...
PERPLEXITY_API_KEY=pplx-...

# Google Gemini — add up to 8 keys for higher free-tier RPM
GEMINI_API_KEY=AIza...
GEMINI_API_KEY_2=AIza...
GEMINI_API_KEY_3=AIza...
# GEMINI_API_KEY_4=AIza...
# GEMINI_API_KEY_5=AIza...

# HuggingFace Router
HF_TOKEN=hf_...

# GitHub Models (use GH_MODELS_TOKEN — GITHUB_* is reserved by GitHub Actions)
GH_MODELS_TOKEN=ghp_...

# Mistral / Codestral
MISTRAL_API_KEY=...
CODESTRAL_API_KEY=...

# Cloudflare Workers AI (10k neurons/day free)
CLOUDFLARE_API_KEY=...
CLOUDFLARE_ACCOUNT_ID=...

# OpenAI (optional — paid)
OPENAI_API_KEY=sk-proj-...

# ── Langfuse observability (optional) ────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_OTEL_HOST=http://langfuse-web:3000
